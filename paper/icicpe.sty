% Define final, set to true if finalcopy is defined
\newif\iffinal
\finalfalse
\def\finalcopy{\finaltrue}

% Indentation
\usepackage{indentfirst}
\setlength\parindent{2.0em}

\usepackage{ifthen}

\renewcommand{\title}[2][english]{%
    % \ifthenelse{\equal{#1}{korean}}%
    %     {\newcommand{\@titleKor}{#2}}{}%
    \ifthenelse{\equal{#1}{english}}%
        {\newcommand{\@titleEng}{#2}}{}%
}
\@onlypreamble{\title}


\renewcommand{\author}[3][english]{%
    % \ifthenelse{\equal{#1}{korean}}
    %     {\newcommand{\@authorKor}{#2}}{}%
    \ifthenelse{\equal{#1}{english}}
        {\newcommand{\@authorEng}{#2}}{}%
}
\@onlypreamble{\author}

% Title stuff, taken from deproc.
\def\maketitle{\par
 \begingroup
  \def\thefootnote{\fnsymbol{footnote}}
  \def\@makefnmark{\hbox to 0pt{$^{\@thefnmark}$\hss}}
  % \twocolumn[\@maketitle] \@thanks
  \@maketitle \@thanks
 \endgroup
 \setcounter{footnote}{0}
 \let\maketitle\relax \let\@maketitle\relax
 \gdef\@thanks{}\gdef\@author{}\gdef\@title{}\let\thanks\relax}

\def\@maketitle{\vbox to \titlebox{\hsize\textwidth
 %\linewidth\hsize \vskip 0.125in minus 0.125in \centering
 \linewidth\hsize \vskip 0.32in minus 0.125in \centering
 {\Large\bf \@titleKor \par} \vskip 0.2in plus 1fil minus 0.1in
 \renewcommand{\arraystretch}{0.8}
 \iffinal
 {\def\and{\unskip\enspace{\rm and}\enspace}%
  \def\And{\end{tabular}\hss \egroup \hskip 1in plus 2fil
          \hbox to 0pt\bgroup\hss \begin{tabular}[t]{c}}%
  \def\AND{\end{tabular}\hss\egroup \hfil\hfil\egroup
          \vskip 0.25in plus 1fil minus 0.125in
          \hbox to \linewidth\bgroup\normalsize \hfil\hfil
             \hbox to 0pt\bgroup\hss \begin{tabular}[t]{c}}
  \hbox to \linewidth\bgroup\normalsize \hfil\hfil
    \hbox to 0pt\bgroup\hss \begin{tabular}[t]{c}\@authorKor
                            \end{tabular}\hss\egroup
    \hfil\hfil\egroup}
  \vskip 0.2in plus 2fil minus 0.1in
  {\large\bf \@titleEng \par} \vskip 0.2in plus 1fil minus 0.1in
  {\def\and{\unskip\enspace{\rm and}\enspace}%
  \def\And{\end{tabular}\hss \egroup \hskip 1in plus 2fil
          \hbox to 0pt\bgroup\hss \begin{tabular}[t]{c}}%
  \def\AND{\end{tabular}\hss\egroup \hfil\hfil\egroup
          \vskip 0.25in plus 1fil minus 0.125in
          \hbox to \linewidth\bgroup\normalsize \hfil\hfil
             \hbox to 0pt\bgroup\hss \begin{tabular}[t]{c}}
  \hbox to \linewidth\bgroup\normalsize \hfil\hfil
    \hbox to 0pt\bgroup\hss \begin{tabular}[t]{c}\@authorEng
                            \end{tabular}\hss\egroup
    \hfil\hfil\egroup}
  \else
    % \vskip 0.2in plus 2fil minus 0.1in
    {\large\bf \@titleEng \par} \vskip 0.2in plus 1fil minus 0.1in
    \begin{tabular}[t]{c}
     Anonymous Author(s) \\
     Affiliation \\
    \end{tabular}%
  \fi
  \vskip 0.2in plus 2fil minus 0.15in
}}

