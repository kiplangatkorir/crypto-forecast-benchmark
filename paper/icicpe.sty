% margins for abstract

\renewenvironment{abstract}{
\centerline{\bf Abstract}\vspace{-1.0ex}
\list{}{%
    \setlength{\leftmargin}{1.6cm}%
    \setlength{\rightmargin}{\leftmargin}%
  }%
\small\item\relax}
{\vskip 2ex}


